<UserControl x:Class="atp_enterprise_app_wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="700">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="ATP Dashboard &amp; Executive Control" 
                   Foreground="{StaticResource TextPrimaryBrush}" 
                   FontSize="22" 
                   FontFamily="{StaticResource TitleFont}" 
                   FontWeight="SemiBold" 
                   Margin="0,0,0,15" />

        <!-- Top status panel -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Active Test Card -->
            <Border Grid.Column="0" Background="{StaticResource BgCardBrush}" 
                    BorderBrush="{StaticResource BorderCardBrush}" BorderThickness="1" 
                    CornerRadius="8" Padding="16" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="AUTOMATED SEQUENCE MONITOR" Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="11" FontWeight="Bold"/>
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,10,0,0">
                        <TextBlock x:Name="ActiveTestLabel" Text="IDLE" Foreground="#FFFFFF" FontSize="20" FontWeight="Bold"/>
                        <Grid Margin="0,8,0,0">
                            <ProgressBar x:Name="SuiteProgressBar" Height="6" Maximum="100" Value="0" Background="#1c2130" Foreground="{StaticResource AccentBlueBrush}"/>
                        </Grid>
                        <TextBlock x:Name="TimeLabel" Text="Elapsed Time: 00:00" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Verdict Card -->
            <Border Grid.Column="1" Background="{StaticResource BgCardBrush}" 
                    BorderBrush="{StaticResource BorderCardBrush}" BorderThickness="1" 
                    CornerRadius="8" Padding="16" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="OVERALL UUT STATUS" Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="11" FontWeight="Bold"/>
                    <Border Grid.Row="1" x:Name="StatusBadge" Background="#1a202d" CornerRadius="4" Margin="0,10,0,0" Height="45">
                        <TextBlock x:Name="StatusBadgeText" Text="AWAITING" Foreground="{StaticResource TextSecondaryBrush}" 
                                   FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Dynamic Circular Gauges Row -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- CPU Gauge -->
            <Border Grid.Column="0" Background="{StaticResource BgCardBrush}" 
                    BorderBrush="{StaticResource BorderCardBrush}" BorderThickness="1" 
                    CornerRadius="8" Padding="15" Margin="0,0,10,0">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="CPU WORKLOAD" Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="11" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <Grid Width="110" Height="110">
                        <Ellipse Stroke="#1e2433" StrokeThickness="7" Width="100" Height="100"/>
                        <Ellipse x:Name="CpuRing" Stroke="{StaticResource AccentBlueBrush}" StrokeThickness="7" 
                                 Width="100" Height="100" StrokeDashArray="314.16" StrokeDashOffset="314.16" 
                                 StrokeStartLineCap="Round" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="-90"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <TextBlock x:Name="CpuText" Text="0%" Foreground="#ffffff" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Memory Gauge -->
            <Border Grid.Column="1" Background="{StaticResource BgCardBrush}" 
                    BorderBrush="{StaticResource BorderCardBrush}" BorderThickness="1" 
                    CornerRadius="8" Padding="15" Margin="10,0,10,0">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="MEMORY UTILIZATION" Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="11" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <Grid Width="110" Height="110">
                        <Ellipse Stroke="#1e2433" StrokeThickness="7" Width="100" Height="100"/>
                        <Ellipse x:Name="RamRing" Stroke="#52c41a" StrokeThickness="7" 
                                 Width="100" Height="100" StrokeDashArray="314.16" StrokeDashOffset="314.16" 
                                 StrokeStartLineCap="Round" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="-90"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <TextBlock x:Name="RamText" Text="0%" Foreground="#ffffff" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Temp Gauge -->
            <Border Grid.Column="2" Background="{StaticResource BgCardBrush}" 
                    BorderBrush="{StaticResource BorderCardBrush}" BorderThickness="1" 
                    CornerRadius="8" Padding="15" Margin="10,0,0,0">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="CORE TEMPERATURE" Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="11" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <Grid Width="110" Height="110">
                        <Ellipse Stroke="#1e2433" StrokeThickness="7" Width="100" Height="100"/>
                        <Ellipse x:Name="TempRing" Stroke="#faad14" StrokeThickness="7" 
                                 Width="100" Height="100" StrokeDashArray="314.16" StrokeDashOffset="314.16" 
                                 StrokeStartLineCap="Round" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="-90"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <TextBlock x:Name="TempText" Text="N/A" Foreground="#ffffff" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
