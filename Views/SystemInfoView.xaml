<UserControl x:Class="atp_enterprise_app_wpf.Views.SystemInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="850">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Title -->
            <RowDefinition Height="Auto" />
            <!-- Scan Controls & Progress -->
            <RowDefinition Height="Auto" />
            <!-- Main Content Area -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="UUT System Hardware Discovery" 
                   Foreground="{StaticResource TextPrimaryBrush}" 
                   FontSize="22" 
                   FontFamily="{StaticResource TitleFont}" 
                   FontWeight="SemiBold" 
                   Margin="0,0,0,10" />

        <!-- Row 1: Scan Controls & Progress Bar -->
        <Border Grid.Row="1" Background="{StaticResource BgCardBrush}" BorderBrush="{StaticResource BorderCardBrush}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="BtnScan" Content="Discover Host Hardware" Style="{StaticResource FluentButton}" Click="ScanHardware_Click" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtProgressStatus" Text="Ready to scan UUT hardware profile." Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" x:Name="TxtPercent" Text="0%" Foreground="{StaticResource AccentBlueBrush}" FontSize="11" FontWeight="Bold"/>
                    </Grid>
                    <ProgressBar x:Name="ProgressScanBar" Height="8" Maximum="100" Value="0" Background="#0b0e14" Foreground="{StaticResource AccentBlueBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 2: Main Body splits into Expanders and Compatibility matrix -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <!-- Column 0: Expanders ScrollViewer -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,10,0">
                <StackPanel>
                    
                    <!-- Expander Style -->
                    <StackPanel.Resources>
                        <Style TargetType="Expander">
                            <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderCardBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Style>
                        
                        <Style x:Key="PropLabel" TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="0,4,0,4"/>
                        </Style>
                        <Style x:Key="PropVal" TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="Margin" Value="10,4,0,4"/>
                        </Style>
                    </StackPanel.Resources>

                    <!-- 1. System Info -->
                    <Expander Header="1. UUT SYSTEM PROFILE" IsExpanded="True">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/><ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.2*"/><ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Manufacturer:" Style="{StaticResource PropLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SysManufacturer" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="SysLabelModel" Text="Model ID:" Style="{StaticResource PropLabel}" Margin="20,4,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" x:Name="SysModel" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Product:" Style="{StaticResource PropLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SysProduct" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Serial Number:" Style="{StaticResource PropLabel}" Margin="20,4,0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" x:Name="SysSerial" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Chassis Type:" Style="{StaticResource PropLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="SysChassis" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="UUID Register:" Style="{StaticResource PropLabel}" Margin="20,4,0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" x:Name="SysUuid" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Asset Identifier:" Style="{StaticResource PropLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SysAsset" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="Machine GUID:" Style="{StaticResource PropLabel}" Margin="20,4,0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="3" x:Name="SysGuid" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>
                        </Grid>
                    </Expander>

                    <!-- 2. BIOS -->
                    <Expander Header="2. BIOS COMPLIANCE PROFILE">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/><ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.2*"/><ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="BIOS Vendor:" Style="{StaticResource PropLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="BiosVendor" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Firmware Version:" Style="{StaticResource PropLabel}" Margin="20,4,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" x:Name="BiosVersion" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Release Date:" Style="{StaticResource PropLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="BiosDate" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Serial Key:" Style="{StaticResource PropLabel}" Margin="20,4,0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" x:Name="BiosSerial" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Firmware Mode:" Style="{StaticResource PropLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="BiosBoot" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Secure Boot:" Style="{StaticResource PropLabel}" Margin="20,4,0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" x:Name="BiosSecure" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>
                        </Grid>
                    </Expander>

                    <!-- 3. Motherboard -->
                    <Expander Header="3. MOTHERBOARD REGISTERS">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/><ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.2*"/><ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Board Brand:" Style="{StaticResource PropLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="MoboVendor" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Board Product:" Style="{StaticResource PropLabel}" Margin="20,4,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" x:Name="MoboProduct" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Board S/N:" Style="{StaticResource PropLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="MoboSerial" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Board Chipset:" Style="{StaticResource PropLabel}" Margin="20,4,0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" x:Name="MoboChipset" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>
                        </Grid>
                    </Expander>

                    <!-- 4. Processor -->
                    <Expander Header="4. PROCESSOR DISCOVERY">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/><ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.2*"/><ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU Model:" Style="{StaticResource PropLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="CpuModel" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Instruction Sets:" Style="{StaticResource PropLabel}" Margin="20,4,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" x:Name="CpuArch" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Physical Cores:" Style="{StaticResource PropLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CpuCores" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Logical Threads:" Style="{StaticResource PropLabel}" Margin="20,4,0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" x:Name="CpuThreads" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Base Clock Rate:" Style="{StaticResource PropLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="CpuClock" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="L3 SmartCache:" Style="{StaticResource PropLabel}" Margin="20,4,0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" x:Name="CpuCache" Text="Awaiting Scan" Style="{StaticResource PropVal}"/>
                        </Grid>
                    </Expander>

                    <!-- 5. Memory -->
                    <Expander Header="5. PHYSICAL MEMORY ENUMERATION">
                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="Detected Slots Summary:" x:Name="TxtTotalMemory" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,8"/>
                            <DataGrid x:Name="GridMemory" Style="{StaticResource FluentDataGrid}" Height="110">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Slot Locator" Binding="{Binding SlotIdentifier}" Width="*"/>
                                    <DataGridTextColumn Header="Module Brand" Binding="{Binding Manufacturer}" Width="*"/>
                                    <DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" Width="1.5*"/>
                                    <DataGridTextColumn Header="Module Size" Binding="{Binding CapacityGb}" Width="*"/>
                                    <DataGridTextColumn Header="Speed" Binding="{Binding ConfiguredSpeed}" Width="*"/>
                                    <DataGridTextColumn Header="Form" Binding="{Binding FormFactor}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>

                    <!-- 6. Storage -->
                    <Expander Header="6. STORAGE CONTROLLER INVENTORY">
                        <DataGrid x:Name="GridStorage" Style="{StaticResource FluentDataGrid}" Height="120" Margin="0,10,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Path" Binding="{Binding DeviceId}" Width="*"/>
                                <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="2*"/>
                                <DataGridTextColumn Header="Interface" Binding="{Binding InterfaceType}" Width="*"/>
                                <DataGridTextColumn Header="Size" Binding="{Binding CapacityGb}" Width="*"/>
                                <DataGridTextColumn Header="SMART Health" Binding="{Binding HealthStatus}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Expander>

                    <!-- 7. Graphics -->
                    <Expander Header="7. GRAPHICS AND ADAPTERS">
                        <DataGrid x:Name="GridGpu" Style="{StaticResource FluentDataGrid}" Height="90" Margin="0,10,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Graphics Model" Binding="{Binding Model}" Width="2*"/>
                                <DataGridTextColumn Header="Driver Version" Binding="{Binding DriverVersion}" Width="1.5*"/>
                                <DataGridTextColumn Header="Dedicated RAM" Binding="{Binding DedicatedMemoryMb}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Expander>

                    <!-- 8. Network Adapters -->
                    <Expander Header="8. LAN &amp; FIBER ADAPTER PORTS">
                        <DataGrid x:Name="GridNics" Style="{StaticResource FluentDataGrid}" Height="120" Margin="0,10,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Port Name" Binding="{Binding AdapterName}" Width="1.5*"/>
                                <DataGridTextColumn Header="MAC Address" Binding="{Binding MacAddress}" Width="1.5*"/>
                                <DataGridTextColumn Header="Link Speed" Binding="{Binding NegotiatedSpeed}" Width="*"/>
                                <DataGridTextColumn Header="Link Status" Binding="{Binding LinkStatus}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Expander>

                    <!-- 9. USB -->
                    <Expander Header="9. USB CONTROLLERS &amp; HUB PORTS">
                        <DataGrid x:Name="GridUsb" Style="{StaticResource FluentDataGrid}" Height="120" Margin="0,10,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Controller / Connected Device" Binding="{Binding FriendlyName}" Width="2.5*"/>
                                <DataGridTextColumn Header="VID" Binding="{Binding VendorID}" Width="*"/>
                                <DataGridTextColumn Header="PID" Binding="{Binding ProductID}" Width="*"/>
                                <DataGridTextColumn Header="Class" Binding="{Binding DeviceClass}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Expander>

                    <!-- 10. Serial Communication -->
                    <Expander Header="10. SERIAL CHANNELS (COM REGISTERS)">
                        <DataGrid x:Name="GridSerial" Style="{StaticResource FluentDataGrid}" Height="100" Margin="0,10,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Port Interface" Binding="{Binding PortName}" Width="*"/>
                                <DataGridTextColumn Header="Device Registry Description" Binding="{Binding DeviceDescription}" Width="3*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Expander>

                    <!-- 11. PCI / PCIe Controllers -->
                    <Expander Header="11. PCI EXPRESS SYSTEM BRIDGE">
                        <DataGrid x:Name="GridPci" Style="{StaticResource FluentDataGrid}" Height="130" Margin="0,10,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Device Name" Binding="{Binding DeviceName}" Width="2*"/>
                                <DataGridTextColumn Header="VEN" Binding="{Binding Vendor}" Width="*"/>
                                <DataGridTextColumn Header="DEV" Binding="{Binding DeviceID}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Expander>

                    <!-- 12. Monitor Layout Displays -->
                    <Expander Header="12. VIDEO DISPLAYS AND MONITORS">
                        <DataGrid x:Name="GridMonitors" Style="{StaticResource FluentDataGrid}" Height="80" Margin="0,10,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Display Adapter" Binding="{Binding DeviceId}" Width="1.5*"/>
                                <DataGridTextColumn Header="Resolution" Binding="{Binding Resolution}" Width="*"/>
                                <DataGridTextColumn Header="Refresh Rate" Binding="{Binding RefreshRate}" Width="*"/>
                                <DataGridTextColumn Header="Orientation" Binding="{Binding Orientation}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Expander>
                </StackPanel>
            </ScrollViewer>

            <!-- Column 1: Hardware Compatibility Matrix Card -->
            <Border Grid.Column="1" Background="{StaticResource BgCardBrush}" BorderBrush="{StaticResource BorderCardBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="10,0,0,0" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="HARDWARE COMPATIBILITY MATRIX" Foreground="{StaticResource AccentBlueBrush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                    <TextBlock Text="Dynamically unlocks or locks testing modules based on active hardware sensor discovery scans." 
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <StackPanel>
                        <StackPanel.Resources>
                            <!-- Styled matrix element rows -->
                            <Style x:Key="BadgePass" TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource StatusPassBrush}"/>
                                <Setter Property="CornerRadius" Value="4"/>
                                <Setter Property="Padding" Value="8,3"/>
                            </Style>
                            <Style x:Key="BadgeFail" TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource StatusFailBrush}"/>
                                <Setter Property="CornerRadius" Value="4"/>
                                <Setter Property="Padding" Value="8,3"/>
                            </Style>
                        </StackPanel.Resources>

                        <!-- Battery Test lock status -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="UPS Battery Test:" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" x:Name="MatrixBattery" Background="#2c3348" CornerRadius="3" Padding="8,4">
                                <TextBlock x:Name="TxtMatrixBattery" Text="LOCKED" Foreground="{StaticResource TextMutedBrush}" FontSize="9.5" FontWeight="Bold"/>
                            </Border>
                        </Grid>

                        <!-- GPS lock status -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="GPS Receiver Sync:" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" x:Name="MatrixGps" Background="#2c3348" CornerRadius="3" Padding="8,4">
                                <TextBlock x:Name="TxtMatrixGps" Text="LOCKED" Foreground="{StaticResource TextMutedBrush}" FontSize="9.5" FontWeight="Bold"/>
                            </Border>
                        </Grid>

                        <!-- 10G Optical link status -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="10G Optical NIC:" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" x:Name="MatrixOptical" Background="#2c3348" CornerRadius="3" Padding="8,4">
                                <TextBlock x:Name="TxtMatrixOptical" Text="LOCKED" Foreground="{StaticResource TextMutedBrush}" FontSize="9.5" FontWeight="Bold"/>
                            </Border>
                        </Grid>

                        <!-- LAN Interfaces detected count -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="LAN Ethernet Ports:" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" x:Name="MatrixLan" Background="{StaticResource AccentBlueBrush}" CornerRadius="3" Padding="8,4">
                                <TextBlock x:Name="TxtMatrixLan" Text="0 DETECTED" Foreground="#FFFFFF" FontSize="9.5" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <Separator BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0.5" Margin="0,20,0,15"/>
                    <TextBlock Text="Discovery engine database updates are automated. Ready to start ATP." 
                               Foreground="{StaticResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
