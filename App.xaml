<Application x:Class="atp_enterprise_app_wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:atp_enterprise_app_wpf"
             xmlns:converters="clr-namespace:atp_enterprise_app_wpf.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Fluent Dark Theme Resources -->
        <SolidColorBrush x:Key="BgAppBrush" Color="#080a0f" />
        <SolidColorBrush x:Key="BgWorkspaceBrush" Color="#10131c" />
        <SolidColorBrush x:Key="BgCardBrush" Color="#161a26" />
        <SolidColorBrush x:Key="BorderCardBrush" Color="#222b3c" />
        <SolidColorBrush x:Key="BorderLightBrush" Color="#1b202e" />
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#2576d9" />
        <SolidColorBrush x:Key="AccentBlueHoverBrush" Color="#4092ff" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#e3e7f0" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8c9cb0" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#57687a" />
        
        <SolidColorBrush x:Key="StatusPassBrush" Color="#1a8038" />
        <SolidColorBrush x:Key="StatusFailBrush" Color="#b82525" />
        <SolidColorBrush x:Key="StatusWarnBrush" Color="#c27a0a" />

        <!-- Value Converters -->
        <converters:StatusToColorConverter x:Key="StatusToColorConverter" />

        <!-- Dark TextBox Style -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0d1017" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderCardBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontFamily" Value="{StaticResource MainFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}" />
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Custom fonts -->
        <FontFamily x:Key="MainFont">Segoe UI, Inter, Arial</FontFamily>
        <FontFamily x:Key="TitleFont">Segoe UI Semibold, Outfit</FontFamily>

        <!-- Standard Button Style -->
        <Style x:Key="FluentButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlueBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontFamily" Value="{StaticResource MainFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBlueHoverBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#222530" />
                    <Setter Property="Foreground" Value="#555966" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="FluentButtonSecondary" TargetType="Button" BasedOn="{StaticResource FluentButton}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderCardBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1d2230" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Ribbon Button Style -->
        <Style x:Key="RibbonButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1a202d" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid Style -->
        <Style x:Key="FluentDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="AlternatingRowBackground" Value="#09ffffff" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderCardBrush}" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="FontFamily" Value="{StaticResource MainFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Style.Resources>
                <!-- Column Header Style -->
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#0b0e14" />
                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="10,8" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Setter Property="BorderBrush" Value="{StaticResource BorderCardBrush}" />
                </Style>
                <!-- Row Style -->
                <Style TargetType="DataGridRow">
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#15ffffff" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
                <!-- Cell Style -->
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="10,8" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                    <ContentPresenter />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#252b3d" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Style.Resources>
        </Style>

        <!-- Floating ambient background glow animation Storyboard -->
        <Storyboard x:Key="AmbientDrift">
            <ColorAnimation Storyboard.TargetName="BgGradientStop"
                            Storyboard.TargetProperty="Color"
                            From="#080a0f" To="#151d2f" Duration="0:0:10"
                            AutoReverse="True" RepeatBehavior="Forever" />
        </Storyboard>
    </Application.Resources>
</Application>
